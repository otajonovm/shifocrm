# ShifoCRM Environment Variables
# Bu fayl namuna sifatida. .env fayl yarating va qiymatlarni kiriting.

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Telegram Bot API (ixtiyoriy)
# Development uchun:
VITE_TELEGRAM_API_URL=http://localhost:3001
VITE_TELEGRAM_API_KEY=my-secret-key-12345

# Production uchun:
# VITE_TELEGRAM_API_URL=https://your-bot-domain.com
# VITE_TELEGRAM_API_KEY=your-production-api-key

# ShifoAI — Onlayn AI yordamchi (ixtiyoriy, DeepSeek)
# Kalitni GitHub ga qo'ymang! Dev serverni .env o'zgargach qayta ishga tushiring.
# VITE_DEEPSEEK_API_KEY=your_deepseek_api_key
# VITE_SHIFOAI_API_BASE=https://api.deepseek.com
# VITE_SHIFOAI_MODEL=deepseek-chat
# (yoki VITE_SHIFOAI_API_KEY — ikkalasi ham ishlaydi)

# Eskiz.uz SMS (faqat server: telegram-bot / Edge Functions — frontend ga qo'ymang!)
# Variant A — tavsiya: my.eskiz.uz dagi SMS shlyuz email + paroli (sayt paroli emas!)
# ESKIZ_EMAIL=your@email.uz
# ESKIZ_PASSWORD=sms_shlyuz_paroli
# Variant B — Postman dan Eskiz login javobidagi JWT (eyJ... bilan boshlanadi, PMAK emas!):
# ESKIZ_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ESKIZ_FROM=4546
